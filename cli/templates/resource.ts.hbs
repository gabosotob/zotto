import { Request } from 'express';
import { Delete, Entity, Get, Id, LocalRepo, NotFoundException, Post, Put, Resource, ResourceFactory, Service } from 'zotto';

interface {{className}}Entity extends Entity {
    name: string;
}

@Service()
class {{className}}Service {
    constructor(private readonly repo: LocalRepo<{{className}}Entity>) {}

    read() {
        return this.repo.readAll();
    }

    readById(id: Id) {
        return this.repo.read(id);
    }

    create(entity: {{className}}Entity) {
        return this.repo.create(entity);
    }

    update(id: Id, entity: {{className}}Entity) {
        return this.repo.update(id, entity);
    }

    delete(id: Id) {
        return this.repo.delete(id);
    }
}

@Resource('{{path}}')
class {{className}} {
    constructor(private readonly service: {{className}}Service) {}

    @Get()
    getAll() {
        return this.service.read();
    }

    @Get(':id')
    async getById({ params }: Request<{ id: Id }>) {
        const data = await this.service.readById(params.id);

        if (!data) {
            throw new NotFoundException('Not found');
        }

        return data;
    }

    @Post()
    post(req: Request) {
        return this.service.create(req.body);
    }

    @Put(':id')
    async put({ params, body }: Request<{ id: Id }>) {
        const idData = await this.service.readById(params.id);

        if (!idData) {
            throw new NotFoundException('Not found');
        }

        return this.service.update(params.id, body);
    }

    @Delete(':id')
    async delete({ params }: Request<{ id: Id }>) {
        const idData = await this.service.readById(params.id);

        if (!idData) {
            throw new NotFoundException('Not found');
        }

        await this.service.delete(params.id);

        return 'Deleted successfully';
    }
}

export default ResourceFactory.create({{className}});
