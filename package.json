{
  "name": "zotto",
  "version": "0.0.13",
  "description": "Components for building a CRUD express.js app",
  "bin": {
    "zotto": "dist/cli/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "start": "nodemon ./tests/sample-server.ts",
    "start:cli": "ts-node ./cli/cli.ts",
    "build": "pnpm install && tsc && tsup && ts-node ./scripts/copy-templates.js",
    "build:watch": "pnpm install && tsc && tsup --watch",
    "pub": "pnpm run build && npm publish --access public",
    "push:version": "pnpm run build && git add . && git commit -m \"chore: update version\" && git push",
    "push:chore": "pnpm run build && git add . && git commit -m \"chore: update\" && git push"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabosotob/zotto.git"
  },
  "keywords": [],
  "author": "Gabriel Soto Barba",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gabosotob/zotto/issues"
  },
  "homepage": "https://github.com/gabosotob/zotto#readme",
  "devDependencies": {
    "@swc/core": "^1.13.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "comment-json": "^4.2.5",
    "handlebars": "^4.7.8",
    "readline": "^1.3.0",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "express": "^5.1.0"
  },
  "packageManager": "pnpm@11.16.0"
}
